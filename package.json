{
  "name": "courier-poland-income",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "lint:spell": "npx cspell \"**/*.{html,md,js,css,json}\"",
    "build": "mkdir -p dist && cp -r src/* dist/ && npm run minify",
    "minify": "npm run minify:css && npm run minify:js",
    "minify:css": "find dist -name *.css -exec npx cleancss -o {} {} \\;",
    "minify:js": "find dist -name *.js -exec npx terser {} -o {} -c -m \\;"
  },
  "devDependencies": {
    "@cspell/dict-pl_pl": "^3.0.6",
    "@cspell/dict-ru_ru": "^2.3.2",
    "@cspell/dict-uk-ua": "^4.0.6",
    "clean-css-cli": "^5.6.3",
    "cspell": "^9.7.0",
    "terser": "^5.46.2"
  }
}